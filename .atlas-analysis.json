  "keyFeatures": [
    "Comprehensive utility functions for Drift Protocol integration",
    "React components and hooks for building Solana dApps",
    "WebSocket clients for real-time market data and orderbook updates",
    "Type-safe serializable data structures for state management",
    "Priority fee calculation and RPC management utilities",
    "Drift Protocol-specific clients and subscription managers",
    "Icon components generated from Figma designs",
    "Browser and Node.js compatible builds"
  ],
  "publicApiSurface": [
    "@drift-labs/common - Main utilities package",
    "Config - Configuration management",
    "Initialize() - SDK initialization",
    "EnvironmentConstants - RPC endpoints and server URLs",
    "CandleClient - Candlestick data client",
    "MarketDataFeed - Market data streaming",
    "DlobWebsocketClient - DLOB orderbook websocket",
    "SwiftClient - Swift server integration",
    "MultiplexWebSocket - WebSocket multiplexing",
    "NumLib - Big number utilities",
    "priorityFees - Priority fee calculation",
    "WalletConnectionState - Wallet state management",
    "@drift-labs/react - React components package",
    "useCommonDriftActions - Drift action hooks",
    "useDriftClientIsReady - Client ready state",
    "useSolBalance - SOL balance tracking",
    "useRpcLatencies - RPC performance monitoring",
    "usePriorityFees - Priority fee hooks",
    "useOraclePrice - Oracle price streaming",
    "useWalletContext - Wallet adapter integration",
    "@drift-labs/icons - Icon components",
    "DriftErrors - Drift protocol error codes",
    "JupV4Errors, JupV6Errors - Jupiter error codes"
  ]
}
